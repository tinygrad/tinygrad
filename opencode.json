{
  "$schema": "https://opencode.ai/config.json",
  "formatter": false,
  "lsp": false,
  "logLevel": "DEBUG",
  "provider": {
    "tinygrad": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Tinygrad (local)",
      "options": {
        "baseURL": "http://localhost:8000/v1",
        "timeout": 900000,
        "chunkTimeout": 600000
      },
      "models": {
        "qwen3.5:4b": {
          "name": "Qwen3.5 4B (local)",
          "limit": {
            "context": 32768,
            "output": 8192
          }
        }
      }
    }
  }
}
